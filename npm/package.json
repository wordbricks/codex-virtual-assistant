{
  "name": "@wordbricks/cva",
  "version": "0.8.0",
  "description": "Codex Virtual Assistant CLI wrapper that installs the native cva binary.",
  "homepage": "https://github.com/wordbricks/codex-virtual-assistant",
  "bugs": {
    "url": "https://github.com/wordbricks/codex-virtual-assistant/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wordbricks/codex-virtual-assistant"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cva": "bin/cva.js"
  },
  "scripts": {
    "postinstall": "node ./lib/install.js"
  },
  "files": [
    "README.md",
    "bin/cva.js",
    "lib/install.js",
    "lib/platform.js"
  ],
  "keywords": [
    "agent",
    "assistant",
    "cli",
    "codex",
    "cva"
  ],
  "cva": {
    "owner": "wordbricks",
    "repo": "codex-virtual-assistant",
    "assetPrefix": "cva",
    "agentBrowserAssetPrefix": "agent-browser"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
